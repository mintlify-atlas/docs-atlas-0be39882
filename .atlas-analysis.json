  "keyFeatures": [
    "Document parsing with vision AI for PDFs and other document formats",
    "Structured data extraction with custom instructions",
    "Document splitting by content categories",
    "AI-powered document editing and transformation",
    "Pipeline support for chaining multiple operations",
    "Async/await support with httpx and aiohttp backends",
    "Job management for async operations with webhooks",
    "File upload support with multiple input formats"
  ],
  "publicApiSurface": [
    "Reducto (sync client)",
    "AsyncReducto (async client)",
    "client.parse.run() - Parse documents synchronously",
    "client.parse.run_job() - Parse documents asynchronously",
    "client.extract.run() - Extract structured data",
    "client.extract.run_job() - Extract data asynchronously",
    "client.split.run() - Split documents by category",
    "client.split.run_job() - Split documents asynchronously",
    "client.edit.run() - Edit documents with AI",
    "client.edit.run_job() - Edit documents asynchronously",
    "client.pipeline.run() - Run multi-step pipelines",
    "client.pipeline.run_job() - Run pipelines asynchronously",
    "client.job.get() - Get job status",
    "client.job.get_all() - List all jobs",
    "client.job.cancel() - Cancel a running job",
    "client.upload() - Upload files directly",
    "client.webhook.run() - Configure webhooks"
  ]
